[flake8]
inline-quotes = "
ignore = E203, E266, W503, N807, N818, F401
max-line-length = 79
max-complexity = 18
select = B,C,E,F,W,T4,B9,Q0,N8,VNE
exclude =
    **migrations
    venv
per-file-ignores =
    manage.py:E501
    task_manager_service/wsgi.py:E501
    task_manager_service/asgi.py:E501
    task_manager_service/settings.py:E501
